#!/bin/bash

# Register custom events
sketchybar --add event aerospace_workspace_change

# Bar appearance
sketchybar --bar \
  height=32 \
  blur_radius=30 \
  position=top \
  sticky=on \
  padding_left=10 \
  padding_right=10 \
  color=0xff002b36 \
  shadow=on

# Default item settings
sketchybar --default \
  icon.color=0xff586e75 \
  label.color=0xff93a1a1 \
  icon.font="JetBrains Mono:Bold:13.0" \
  label.font="JetBrains Mono:Regular:13.0" \
  icon.padding_left=6 \
  icon.padding_right=4 \
  label.padding_left=0 \
  label.padding_right=6 \
  label.y_offset=1 \
  icon.y_offset=1 \
  padding_left=4 \
  padding_right=4

# --- Left side ---

# AeroSpace workspaces
for sid in 1 2 3 4 5 6 7 8 9; do
  sketchybar --add item space.$sid left \
    --subscribe space.$sid aerospace_workspace_change \
    --set space.$sid \
      label="$sid" \
      label.color=0xff586e75 \
      label.padding_left=8 \
      label.padding_right=8 \
      icon.drawing=off \
      background.color=0xff073642 \
      background.corner_radius=5 \
      background.height=24 \
      background.drawing=off \
      click_script="aerospace workspace $sid" \
      script="$HOME/.config/sketchybar/plugins/aerospace.sh $sid"
done

# Active app name
sketchybar --add item front_app left \
  --set front_app \
    icon.drawing=off \
    label.color=0xff268bd2 \
    label.font="JetBrains Mono:Bold:13.0" \
    label.padding_left=10 \
    script="$HOME/.config/sketchybar/plugins/front_app.sh" \
  --subscribe front_app front_app_switched

# --- Right side ---

# Clock
sketchybar --add item clock right \
  --set clock \
    update_freq=30 \
    icon="" \
    script="$HOME/.config/sketchybar/plugins/clock.sh"

# Battery
sketchybar --add item battery right \
  --set battery \
    update_freq=120 \
    icon="BAT" \
    script="$HOME/.config/sketchybar/plugins/battery.sh"

# Volume
sketchybar --add item volume right \
  --set volume \
    icon="VOL" \
    script="$HOME/.config/sketchybar/plugins/volume.sh" \
  --subscribe volume volume_change

# Network
sketchybar --add item network right \
  --set network \
    update_freq=3 \
    icon="NET" \
    label.width=62 \
    label.align=left \
    script="$HOME/.config/sketchybar/plugins/network.sh"

# RAM
sketchybar --add item ram right \
  --set ram \
    update_freq=5 \
    icon="RAM" \
    script="$HOME/.config/sketchybar/plugins/ram.sh"

# CPU
sketchybar --add item cpu right \
  --set cpu \
    update_freq=5 \
    icon="CPU" \
    script="$HOME/.config/sketchybar/plugins/cpu.sh"

# Assign each workspace item to its owning monitor's display index,
# so each monitor's bar shows only its own workspaces.
# Re-run on display topology change (connect/disconnect).
sketchybar --add item space_displays_updater left \
  --set space_displays_updater \
    drawing=off \
    script="$HOME/.config/sketchybar/plugins/update_space_displays.sh" \
  --subscribe space_displays_updater display_change

"$HOME/.config/sketchybar/plugins/update_space_displays.sh"

# Force all scripts to run once
sketchybar --update
